# Real X5 RetailHero dataset -- large (4.8GB) and not to be redistributed
# via a public repo (competition data, not ours to publish). See
# reports/data_download_report.md for how to obtain and place it locally.
data/raw/

# Intermediate pipeline artifacts derived from the raw dataset -- large
# (one file >200MB) and fully reproducible by re-running src/build_client_aggregates.py.
data/interim/

